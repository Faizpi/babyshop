rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - each user can only access their own data
    match /users/{userId} {
      // User can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Warung subcollection
      match /warung/{warungId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Barang subcollection
      match /barang/{barangId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Riwayat subcollection
      match /riwayat/{riwayatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
